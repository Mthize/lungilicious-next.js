enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum LayoutVariant {
  LEFT_MEDIA
  RIGHT_MEDIA
  CENTERED
  OFFSET
  STACKED
}

enum ThemeAccent {
  HIBISCUS
  BAOBAB
  TAMARIND
  NEUTRAL
}

enum EmphasisStyle {
  EDITORIAL
  CATALOG
  CAMPAIGN
  STORY
}

enum BadgeType {
  SUGAR_FREE
  BANTING_FRIENDLY
  VEGAN_FRIENDLY
  PLANT_BASED
  HERBAL
  NATURALLY_CRAFTED
}

enum DesignAssetType {
  MOTIF
  ACCENT
  BACKGROUND
}

enum PromotionType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

model Category {
  id             String   @id @default(uuid())
  name           String
  slug           String   @unique
  description    String?
  parentId       String?
  imageUrl       String?
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@map("categories")
}

model Product {
  id                  String        @id @default(uuid())
  slug                String        @unique
  name                String
  headline            String?
  subheadline         String?
  shortDescription    String
  longDescription     String
  storyIntro          String?
  ingredientNarrative String?
  usageSuggestions    String?
  flavorNotes         String?
  wellnessPositioning String?
  status              ProductStatus @default(DRAFT)
  isFeatured          Boolean       @default(false)
  categoryId          String
  layoutVariant       LayoutVariant @default(LEFT_MEDIA)
  themeAccent         ThemeAccent   @default(NEUTRAL)
  emphasisStyle       EmphasisStyle @default(CATALOG)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?

  category   Category           @relation(fields: [categoryId], references: [id])
  variants   ProductVariant[]
  images     ProductImage[]
  badges     ProductBadge[]
  seo        ProductSeo?
  attributes ProductAttribute[]

  @@index([categoryId])
  @@index([status])
  @@map("products")
}

model ProductVariant {
  id             String   @id @default(uuid())
  productId      String
  sku            String   @unique
  name           String
  price          Decimal  @db.Decimal(10, 2)
  compareAtPrice Decimal? @db.Decimal(10, 2)
  isDefault      Boolean  @default(false)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id])
  prices  Price[]

  @@index([productId])
  @@map("product_variants")
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String
  altText   String
  caption   String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@map("product_images")
}

model ProductBadge {
  id        String    @id @default(uuid())
  productId String
  badgeType BadgeType

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@map("product_badges")
}

model ProductSeo {
  id             String  @id @default(uuid())
  productId      String  @unique
  title          String
  description    String
  canonicalUrl   String?
  openGraphImage String?

  product Product @relation(fields: [productId], references: [id])

  @@map("product_seo")
}

model ProductAttribute {
  id        String @id @default(uuid())
  productId String
  key       String
  value     String
  sortOrder Int    @default(0)

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@map("product_attributes")
}

model DesignAsset {
  id              String          @id @default(uuid())
  name            String
  type            DesignAssetType
  url             String
  altText         String
  botanicalFamily String?
  createdAt       DateTime        @default(now())

  @@map("design_assets")
}

model Price {
  id               String    @id @default(uuid())
  productVariantId String
  amount           Decimal   @db.Decimal(10, 2)
  currency         String    @default("ZAR")
  validFrom        DateTime?
  validUntil       DateTime?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())

  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])

  @@index([productVariantId])
  @@map("prices")
}

model Promotion {
  id             String        @id @default(uuid())
  name           String
  description    String?
  type           PromotionType
  discountValue  Decimal       @db.Decimal(10, 2)
  minOrderAmount Decimal?      @db.Decimal(10, 2)
  maxUsageCount  Int?
  usedCount      Int           @default(0)
  isActive       Boolean       @default(true)
  validFrom      DateTime?
  validUntil     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  couponCodes CouponCode[]

  @@map("promotions")
}

model CouponCode {
  id            String   @id @default(uuid())
  promotionId   String
  code          String   @unique
  maxUsageCount Int?
  usedCount     Int      @default(0)
  isActive      Boolean  @default(true)
  expiresAt     DateTime?
  createdAt     DateTime @default(now())

  carts       Cart[]             
  promotion   Promotion          @relation(fields: [promotionId], references: [id])
  redemptions CouponRedemption[]

  @@index([promotionId])
  @@map("coupon_codes")
}

model CouponRedemption {
  id             String   @id @default(uuid())
  couponCodeId   String
  orderId        String
  customerId     String
  discountAmount Decimal  @db.Decimal(10, 2)
  redeemedAt     DateTime @default(now())

  couponCode CouponCode @relation(fields: [couponCodeId], references: [id])

  @@index([couponCodeId])
  @@index([orderId])
  @@index([customerId])
  @@map("coupon_redemptions")
}
