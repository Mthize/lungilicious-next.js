enum CartStatus {
  ACTIVE
  MERGED
  ABANDONED
  CONVERTED
}

enum CheckoutStatus {
  PENDING
  PAYMENT_INITIATED
  COMPLETED
  EXPIRED
  ABANDONED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  RELEASED
  EXPIRED
}

enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAYMENT_PROCESSING
  PAID
  AWAITING_FULFILLMENT
  FULFILLED
  CANCELLED
  PARTIALLY_REFUNDED
  REFUNDED
  PAYMENT_FAILED
}

enum ShipmentStatus {
  UNFULFILLED
  PACKED
  SHIPPED
  DELIVERED
  RETURNED
}

model Cart {
  id         String     @id @default(uuid())
  customerId String?
  sessionId  String?
  status     CartStatus @default(ACTIVE)
  expiresAt  DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  items            CartItem[]
  checkoutSessions CheckoutSession[]

  @@index([customerId])
  @@index([sessionId])
  @@map("carts")
}

model CartItem {
  id               String   @id @default(uuid())
  cartId           String
  productVariantId String
  quantity         Int
  priceAtAdd       Decimal  @db.Decimal(10, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  cart Cart @relation(fields: [cartId], references: [id])

  @@index([cartId])
  @@map("cart_items")
}

model CheckoutSession {
  id               String         @id @default(uuid())
  cartId           String
  customerId       String?
  addressId        String?
  shippingMethodId String?
  status           CheckoutStatus @default(PENDING)
  expiresAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  cart              Cart              @relation(fields: [cartId], references: [id])
  stockReservations StockReservation[]

  @@index([cartId])
  @@index([customerId])
  @@map("checkout_sessions")
}

model StockReservation {
  id                String            @id @default(uuid())
  productVariantId  String
  quantity          Int
  orderId           String?
  checkoutSessionId String?
  status            ReservationStatus @default(PENDING)
  expiresAt         DateTime
  confirmedAt       DateTime?
  releasedAt        DateTime?
  createdAt         DateTime          @default(now())

  checkoutSession CheckoutSession? @relation(fields: [checkoutSessionId], references: [id])

  @@index([productVariantId])
  @@index([expiresAt])
  @@map("stock_reservations")
}

model Inventory {
  id                String   @id @default(uuid())
  productVariantId  String   @unique
  availableQuantity Int      @default(0)
  reservedQuantity  Int      @default(0)
  soldQuantity      Int      @default(0)
  lowStockThreshold Int      @default(5)
  updatedAt         DateTime @updatedAt

  @@map("inventory")
}

model Order {
  id          String      @id @default(uuid())
  orderNumber String      @unique
  customerId  String
  addressId   String
  status      OrderStatus @default(DRAFT)
  subtotal    Decimal     @db.Decimal(10, 2)
  shippingFee Decimal     @db.Decimal(10, 2)
  taxAmount   Decimal     @db.Decimal(10, 2)
  totalAmount Decimal     @db.Decimal(10, 2)
  currency    String      @default("ZAR")
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  items         OrderItem[]
  statusHistory OrderStatusHistory[]
  shipments     Shipment[]

  @@index([customerId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id                  String  @id @default(uuid())
  orderId             String
  productVariantId    String
  productSnapshotName String
  sku                 String
  quantity            Int
  unitPrice           Decimal @db.Decimal(10, 2)
  lineTotal           Decimal @db.Decimal(10, 2)

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model OrderStatusHistory {
  id         String   @id @default(uuid())
  orderId    String
  fromStatus String
  toStatus   String
  changedBy  String
  reason     String?
  createdAt  DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("order_status_history")
}

model ShippingMethod {
  id            String   @id @default(uuid())
  name          String
  description   String?
  price         Decimal  @db.Decimal(10, 2)
  estimatedDays Int
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  shipments Shipment[]

  @@map("shipping_methods")
}

model Shipment {
  id               String         @id @default(uuid())
  orderId          String
  shippingMethodId String?
  trackingCode     String?
  carrier          String?
  status           ShipmentStatus @default(UNFULFILLED)
  shippedAt        DateTime?
  deliveredAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  order          Order           @relation(fields: [orderId], references: [id])
  shippingMethod ShippingMethod? @relation(fields: [shippingMethodId], references: [id])
  events         ShipmentEvent[]

  @@index([orderId])
  @@map("shipments")
}

model ShipmentEvent {
  id          String   @id @default(uuid())
  shipmentId  String
  status      String
  description String
  occurredAt  DateTime
  createdAt   DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id])

  @@index([shipmentId])
  @@map("shipment_events")
}
